---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const siteUrl = "https://getexpatdrive.com";

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl,
    },
    ...items.map((item, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: item.label,
      ...(item.href ? { item: `${siteUrl}${item.href}` } : {}),
    })),
  ],
};
---

<nav aria-label="Breadcrumb" class="text-sm text-text-muted mb-6">
  <ol class="flex flex-wrap items-center gap-1">
    <li>
      <a href="/" class="hover:text-navy transition-colors">Home</a>
    </li>
    {items.map((item) => (
      <li class="flex items-center gap-1">
        <span aria-hidden="true">/</span>
        {item.href ? (
          <a href={item.href} class="hover:text-navy transition-colors">{item.label}</a>
        ) : (
          <span class="text-text-secondary" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
