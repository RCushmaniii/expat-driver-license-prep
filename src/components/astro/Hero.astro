---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const { title, subtitle, ctaText, ctaHref, secondaryText, secondaryHref } = Astro.props;
---

<section class="bg-navy text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
        {title}
      </h1>
      <p class="mt-4 sm:mt-6 text-lg sm:text-xl text-white/80 leading-relaxed">
        {subtitle}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center rounded-lg bg-white text-navy font-semibold px-8 py-4 text-lg hover:bg-surface transition-colors touch-target"
        >
          {ctaText}
        </a>
        {secondaryText && secondaryHref && (
          <a
            href={secondaryHref}
            class="inline-flex items-center justify-center rounded-lg border-2 border-white/30 text-white font-medium px-8 py-4 text-lg hover:bg-white/10 transition-colors touch-target"
          >
            {secondaryText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
