---
import Icon from "./Icon.astro";

interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="card text-center sm:text-left">
  <div class="mb-3 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-navy/5">
    <Icon name={icon} size="w-5 h-5" class="text-navy" />
  </div>
  <h3 class="text-lg font-semibold text-navy">{title}</h3>
  <p class="mt-2 text-sm text-text-secondary leading-relaxed">{description}</p>
</div>
