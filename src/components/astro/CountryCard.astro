---
import Icon from "./Icon.astro";

interface Props {
  flagIcon: string;
  country: string;
  region: string;
  href: string;
  questionCount: number;
  active?: boolean;
}

const { flagIcon, country, region, href, questionCount, active = true } = Astro.props;
---

{active ? (
  <a
    href={href}
    class="card flex items-center gap-4 hover:border-navy hover:shadow-md transition-all group"
  >
    <div class="w-10 h-10 rounded-lg bg-navy/5 flex items-center justify-center shrink-0">
      <Icon name={flagIcon} size="w-5 h-5" class="text-navy" />
    </div>
    <div class="flex-1">
      <h3 class="font-semibold text-navy group-hover:text-navy-light transition-colors">
        {country} — {region}
      </h3>
      <p class="text-sm text-text-secondary mt-1">
        {questionCount} questions · Written exam + Simulator
      </p>
    </div>
    <Icon name="chevron-right" size="w-5 h-5" class="text-text-muted group-hover:text-navy transition-colors" />
  </a>
) : (
  <div class="card flex items-center gap-4 opacity-50 cursor-default">
    <div class="w-10 h-10 rounded-lg bg-border/50 flex items-center justify-center shrink-0">
      <Icon name={flagIcon} size="w-5 h-5" class="text-text-muted" />
    </div>
    <div class="flex-1">
      <h3 class="font-semibold text-text-secondary">
        {country} — {region}
      </h3>
      <p class="text-sm text-text-muted mt-1">Coming soon</p>
    </div>
  </div>
)}
