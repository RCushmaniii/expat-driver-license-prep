---
import MainLayout from "@layouts/MainLayout.astro";

const whatsappNumber = "523315590572";
const whatsappMessage = encodeURIComponent(
  "Hi! I have a question about ExpatDrive."
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact ExpatDrive",
  description: "Get in touch with the ExpatDrive team.",
  publisher: {
    "@type": "Organization",
    name: "CushLabs AI Services",
    url: "https://cushlabs.ai",
  },
};
---

<MainLayout
  title="Contact | ExpatDrive"
  description="Get in touch with the ExpatDrive team for questions, feedback, or content corrections."
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-2">Contact</h1>
    <p class="text-text-secondary mb-10">
      Questions, feedback, content corrections — we want to hear from you.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Contact Form (2 cols) -->
      <div class="lg:col-span-2">
        <div class="card">
          <h2 class="text-xl font-bold text-navy mb-6">Send us a message</h2>
          <form
            id="contact-form"
            action="https://formspree.io/f/mlgwnqky"
            method="POST"
            class="space-y-4"
          >
            <input type="hidden" name="_subject" value="ExpatDrive Contact Form" />
            <input type="hidden" name="_language" value="en" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-text-primary mb-1">
                  Name <span class="text-error">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-border px-4 py-3 text-text-primary bg-surface-white focus:border-navy focus:ring-1 focus:ring-navy outline-none transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-text-primary mb-1">
                  Email <span class="text-error">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="_replyto"
                  required
                  class="w-full rounded-lg border border-border px-4 py-3 text-text-primary bg-surface-white focus:border-navy focus:ring-1 focus:ring-navy outline-none transition-colors"
                  placeholder="you@example.com"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-text-primary mb-1">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full rounded-lg border border-border px-4 py-3 text-text-primary bg-surface-white focus:border-navy focus:ring-1 focus:ring-navy outline-none transition-colors"
              >
                <option value="General question">General question</option>
                <option value="Content correction">Content correction (wrong answer/translation)</option>
                <option value="New region request">Request a new region</option>
                <option value="Bug report">Bug report</option>
                <option value="CushLabs inquiry">CushLabs AI Services inquiry</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text-primary mb-1">
                Message <span class="text-error">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full rounded-lg border border-border px-4 py-3 text-text-primary bg-surface-white focus:border-navy focus:ring-1 focus:ring-navy outline-none transition-colors resize-y"
                placeholder="How can we help?"
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="btn-primary w-full sm:w-auto"
            >
              Send Message
            </button>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="form-success" class="hidden text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-success-bg mb-4">
              <svg class="w-8 h-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-navy mb-2">Message sent</h3>
            <p class="text-text-secondary">We'll get back to you within 1-2 business days.</p>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Direct channels -->
        <div class="card">
          <h3 class="font-semibold text-navy mb-4">Direct channels</h3>

          <!-- Email (anti-scraper) -->
          <div class="mb-4">
            <div class="text-sm text-text-muted mb-1">Email</div>
            <a
              id="email-link"
              href="#"
              data-u="info"
              data-d="cushlabs.ai"
              class="text-navy-light underline hover:text-navy font-medium"
            >
              <span class="email-user">info</span><span class="email-at">[at]</span><span class="email-domain">cushlabs.ai</span>
            </a>
            <p class="text-xs text-text-muted mt-1">1-2 business day response</p>
          </div>

          <!-- WhatsApp -->
          <div>
            <div class="text-sm text-text-muted mb-1">WhatsApp</div>
            <a
              href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-navy-light underline hover:text-navy font-medium"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Message on WhatsApp
            </a>
            <p class="text-xs text-text-muted mt-1">Fastest response — popular in Mexico</p>
          </div>
        </div>

        <!-- Content corrections -->
        <div class="card">
          <h3 class="font-semibold text-navy mb-2">Content corrections</h3>
          <p class="text-sm text-text-secondary">
            Took the exam recently and notice something different? Include the question number and what you saw — we'll verify and update.
          </p>
        </div>

        <!-- New regions -->
        <div class="card">
          <h3 class="font-semibold text-navy mb-2">Want your region?</h3>
          <p class="text-sm text-text-secondary">
            We're expanding. Tell us where you live and we'll prioritize based on demand. Access to the official question bank helps us move faster.
          </p>
        </div>

        <!-- CushLabs CTA -->
        <div class="card bg-navy/5 border-navy/10">
          <h3 class="font-semibold text-navy mb-2">Built by CushLabs</h3>
          <p class="text-sm text-text-secondary mb-3">
            ExpatDrive is built by CushLabs AI Services. We build AI-powered tools and custom software for businesses.
          </p>
          <a
            href="https://cushlabs.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary text-sm py-2 px-4"
          >
            Visit CushLabs.ai
          </a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  // Anti-scraper email assembly — builds mailto href and readable text from data attributes
  const emailLink = document.getElementById("email-link");
  if (emailLink) {
    const u = emailLink.getAttribute("data-u");
    const d = emailLink.getAttribute("data-d");
    if (u && d) {
      const addr = `${u}@${d}`;
      emailLink.setAttribute("href", `mailto:${addr}`);
      emailLink.textContent = addr;
    }
  }

  // Form submission with success state
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successDiv = document.getElementById("form-success") as HTMLDivElement;

  if (form && submitBtn && successDiv) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          form.classList.add("hidden");
          successDiv.classList.remove("hidden");
        } else {
          submitBtn.textContent = "Send Message";
          submitBtn.disabled = false;
          alert("Something went wrong. Please try email or WhatsApp instead.");
        }
      } catch {
        submitBtn.textContent = "Send Message";
        submitBtn.disabled = false;
        alert("Something went wrong. Please try email or WhatsApp instead.");
      }
    });
  }
</script>
