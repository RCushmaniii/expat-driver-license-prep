---
import MainLayout from "@layouts/MainLayout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About ExpatDrive",
  description: "Learn about ExpatDrive — the bilingual study companion for expats preparing for driver's license exams abroad.",
  publisher: {
    "@type": "Organization",
    name: "CushLabs AI Services",
    url: "https://cushlabs.ai",
  },
};
---

<MainLayout
  title="About | ExpatDrive"
  description="Learn about ExpatDrive — the bilingual study companion for expats preparing for driver's license exams abroad."
  jsonLd={jsonLd}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-navy mb-6">About ExpatDrive</h1>

    <div class="space-y-6 text-text-primary leading-relaxed">
      <p>
        ExpatDrive exists because getting a driver's license in a foreign country shouldn't feel like guesswork.
      </p>

      <p>
        When you move abroad, one of the first practical hurdles is getting legal to drive. The written exam
        is often in a language you're still learning, the official English translations can be confusing, and
        study materials are scattered or outdated. ExpatDrive fixes that.
      </p>

      <h2 class="text-2xl font-bold text-navy mt-8">What we do</h2>

      <p>
        We take the official question banks from driver's license exams around the world and build
        proper study tools around them. Every question is presented bilingually — the original language
        side-by-side with clear English translations. Where official government English translations exist,
        we include those too so you know exactly what you'll see on test day.
      </p>

      <p>
        Our study tools use spaced repetition, the most effective memorization technique known to science.
        Questions you miss come back more frequently. Questions you know well space out over days and weeks.
        It's the same method used by medical students and language learners worldwide.
      </p>

      <p>
        We also integrate AI-powered study coaching — get personalized readiness assessments and
        conversational explanations for questions you miss, powered by Claude AI.
      </p>

      <h2 class="text-2xl font-bold text-navy mt-8">Why this matters</h2>

      <p>
        Driving without a local license puts you at risk — legally, financially, and in terms of insurance.
        For most expats, it's not a matter of driving skill but of studying unfamiliar rules in an unfamiliar
        language. ExpatDrive removes that barrier.
      </p>

      <h2 class="text-2xl font-bold text-navy mt-8">Your data</h2>

      <p>
        ExpatDrive stores all your study progress locally in your browser. We don't collect personal data,
        don't require an account, and don't track your behavior. Your study data stays on your device.
      </p>
    </div>

    <!-- CushLabs Section -->
    <div class="mt-12 pt-10 border-t border-border">
      <div class="card bg-navy/5 border-navy/10">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <div class="shrink-0">
            <div class="w-16 h-16 rounded-xl bg-navy flex items-center justify-center">
              <span class="text-white font-bold text-xl">CL</span>
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-navy mb-2">Built by CushLabs AI Services</h2>
            <p class="text-text-secondary mb-4">
              ExpatDrive is a product of <a href="https://cushlabs.ai" class="text-navy-light underline hover:text-navy font-medium" target="_blank" rel="noopener noreferrer">CushLabs AI Services</a> — a technology consultancy that helps businesses leverage AI to solve real problems.
            </p>
            <p class="text-text-secondary mb-6">
              We build custom AI tools, web applications, and automation solutions. From intelligent document processing to bilingual content platforms like ExpatDrive — we turn complex technology into practical products that work.
            </p>
            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href="https://cushlabs.ai"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary text-sm"
              >
                Visit CushLabs.ai
              </a>
              <a
                href="https://cushlabs.ai/consultation"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary text-sm"
              >
                Book a Consultation
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
