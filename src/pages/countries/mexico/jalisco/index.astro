---
import MainLayout from "@layouts/MainLayout.astro";
import Breadcrumb from "@components/astro/Breadcrumb.astro";
import ExamInfo from "@components/astro/ExamInfo.astro";
import DocumentChecklist from "@components/astro/DocumentChecklist.astro";
import ProcessGuide from "@components/astro/ProcessGuide.astro";
import Icon from "@components/astro/Icon.astro";
import type { RegionMeta } from "@lib/types";

import meta from "../../../../../content/countries/mexico/jalisco/meta.json";
import processMarkdown from "../../../../../content/countries/mexico/jalisco/process.md?raw";
import insuranceMarkdown from "../../../../../content/countries/mexico/jalisco/insurance-guide.md?raw";
import rentalMarkdown from "../../../../../content/countries/mexico/jalisco/rental-guide.md?raw";

const regionMeta = meta as RegionMeta;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: "Jalisco Driver's License Exam Preparation",
  description:
    "Complete guide and study materials for the Jalisco, Mexico driver's license written exam. 103 official questions with bilingual translations.",
  provider: {
    "@type": "Organization",
    name: "ExpatDrive",
    url: "https://getexpatdrive.com",
  },
  hasCourseInstance: {
    "@type": "CourseInstance",
    courseMode: "Online",
    courseWorkload: "PT5H",
  },
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Can I drive in Mexico with my US or Canadian driver's license?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tourists can legally drive in Mexico with a valid foreign license. However, if you are a resident (Residente Temporal or Permanente), you should get a Mexican driver's license. In practice, traffic officers may or may not accept a foreign license from a resident — having a Mexican license avoids the hassle and potential fines.",
      },
    },
    {
      "@type": "Question",
      name: "What documents do I need to get a driver's license in Jalisco, Mexico?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "You need: (1) Official photo ID — passport or immigration document (Residente Temporal/Permanente card), (2) Proof of address — utility bill or bank statement less than 3 months old with a Jalisco address, (3) CURP — foreigners with residency can obtain one at gob.mx/curp, (4) Blood type certificate from any lab or Red Cross (~100-200 MXN), (5) Two passport-size photos (color, white background), and (6) Payment receipt for the license fee (~800-1,200 MXN).",
      },
    },
    {
      "@type": "Question",
      name: "Can I take the Jalisco driver's license exam in English?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The computer-based exam is in Spanish only. However, you can request a paper English version of the exam — ask for it at the exam window before starting. You can also bring an interpreter who can read and translate questions, but they cannot answer for you.",
      },
    },
    {
      "@type": "Question",
      name: "How many questions are on the Jalisco driver's license exam?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The exam has 20 multiple-choice questions randomly selected from a bank of 103 official questions. Each question has 3 options (A, B, C). You need to score 80% (16 out of 20) to pass. The time limit is 30 minutes.",
      },
    },
    {
      "@type": "Question",
      name: "What happens if I fail the Jalisco driver's license exam?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "If you fail, you must wait 15 calendar days before retaking the exam. You pay the exam fee again. Only the failed portion needs to be retaken (written or simulator). There is no limit on retake attempts.",
      },
    },
    {
      "@type": "Question",
      name: "How much does a driver's license cost in Jalisco, Mexico?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The license fee is approximately 800 MXN for a 3-year standard license or 1,100 MXN for a 5-year license. Including blood type certificate (~100-200 MXN) and passport photos (~50-80 MXN), budget about 1,200-1,500 MXN total (~$70-85 USD).",
      },
    },
    {
      "@type": "Question",
      name: "What is the Jalisco driving simulator test?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Jalisco introduced a driving simulator test in 2025, replacing the on-road driving test at most locations. You sit in a simulator pod with a steering wheel, pedals, and mirrors, and complete scenarios including parallel parking, navigating intersections, yielding to pedestrians, and emergency situations. Tips: exaggerate head movements for mirror checks, come to a dead stop at stop signs, and use turn signals for everything.",
      },
    },
    {
      "@type": "Question",
      name: "Do I need to surrender my foreign driver's license to get a Mexican license?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. Mexico does not require you to surrender your foreign driver's license. You can hold both a Mexican license and your home country license simultaneously.",
      },
    },
    {
      "@type": "Question",
      name: "Is car insurance mandatory in Mexico?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Since 2019, liability insurance (seguro de responsabilidad civil) is mandatory for all vehicles on federal highways in Mexico. Jalisco state law also requires liability coverage on local roads. US and Canadian auto insurance policies almost certainly do not cover you in Mexico — you need a Mexican-issued policy. Basic liability starts around 2,000-4,000 MXN per year.",
      },
    },
    {
      "@type": "Question",
      name: "Where is the driver's license office in Guadalajara, Jalisco?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The main office is the Direccion General de Transporte at Av. Alcalde #1351, Col. Miraflores, Guadalajara, Jalisco. Office hours are typically 8:00 AM to 3:00 PM, Monday through Friday. Arrive by 7:30 AM as lines form early.",
      },
    },
  ],
};

const breadcrumbs = [
  { label: "Mexico", href: "#" },
  { label: "Jalisco" },
];
---

<MainLayout
  title="Jalisco Driver's License Guide | ExpatDrive"
  description="Complete guide for getting your driver's license in Jalisco, Mexico. 103 official questions, bilingual translations, process guide, and study tools."
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={breadcrumbs} />

    <div class="flex items-center gap-4 mb-8">
      <div class="w-12 h-12 rounded-xl bg-navy/5 flex items-center justify-center shrink-0">
        <Icon name="flag-mx" size="w-6 h-6" class="text-navy" />
      </div>
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-navy">
          Jalisco Driver's License Guide
        </h1>
        <p class="text-text-secondary mt-1">
          Everything you need to know to get your license in Jalisco, Mexico
        </p>
      </div>
    </div>

    <!-- Study CTAs -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <a
        href="/countries/mexico/jalisco/exam"
        class="card hover:border-navy hover:shadow-md transition-all text-center group"
      >
        <div class="mb-2 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-navy/5 group-hover:bg-navy/10 transition-colors">
          <Icon name="exam" size="w-5 h-5" class="text-navy" />
        </div>
        <h3 class="font-semibold text-navy group-hover:text-navy-light">Practice Exam</h3>
        <p class="text-xs text-text-muted mt-1">20 random questions</p>
      </a>
      <a
        href="/countries/mexico/jalisco/study"
        class="card hover:border-navy hover:shadow-md transition-all text-center group"
      >
        <div class="mb-2 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-navy/5 group-hover:bg-navy/10 transition-colors">
          <Icon name="flashcards" size="w-5 h-5" class="text-navy" />
        </div>
        <h3 class="font-semibold text-navy group-hover:text-navy-light">Flashcards</h3>
        <p class="text-xs text-text-muted mt-1">Spaced repetition study</p>
      </a>
      <a
        href="/countries/mexico/jalisco/vocabulary"
        class="card hover:border-navy hover:shadow-md transition-all text-center group"
      >
        <div class="mb-2 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-navy/5 group-hover:bg-navy/10 transition-colors">
          <Icon name="vocabulary" size="w-5 h-5" class="text-navy" />
        </div>
        <h3 class="font-semibold text-navy group-hover:text-navy-light">Vocabulary</h3>
        <p class="text-xs text-text-muted mt-1">Key driving terms</p>
      </a>
      <a
        href="/countries/mexico/jalisco/signs"
        class="card hover:border-navy hover:shadow-md transition-all text-center group"
      >
        <div class="mb-2 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-navy/5 group-hover:bg-navy/10 transition-colors">
          <Icon name="road-signs" size="w-5 h-5" class="text-navy" />
        </div>
        <h3 class="font-semibold text-navy group-hover:text-navy-light">Road Signs</h3>
        <p class="text-xs text-text-muted mt-1">Visual sign study</p>
      </a>
    </div>

    <!-- Exam Info -->
    <div class="mb-8">
      <ExamInfo meta={regionMeta} />
    </div>

    <!-- Document Checklist -->
    <div class="mb-8">
      <DocumentChecklist documents={regionMeta.required_documents} />
    </div>

    <!-- Process Guide -->
    <div class="card mb-8">
      <ProcessGuide markdown={processMarkdown} />
    </div>

    <!-- Insurance Guide -->
    <div class="card mb-8">
      <ProcessGuide markdown={insuranceMarkdown} />
    </div>

    <!-- Car Rental Guide -->
    <div class="card">
      <ProcessGuide markdown={rentalMarkdown} />
    </div>
  </div>

  <!-- FAQPage JSON-LD for AI search -->
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
</MainLayout>
