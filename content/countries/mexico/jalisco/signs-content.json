  "SR-16": {
    "nameEs": "Anchura libre restringida",
    "nameEn": "Restricted free width",
    "descriptionEn": "Indicates the maximum allowed width (in meters) for vehicles passing through a narrow area where space is too limited for two vehicles to pass simultaneously.",
    "descriptionEs": "Indica el ancho máximo permitido (en metros) para vehículos que pasan por una zona estrecha donde el espacio es demasiado limitado para que dos vehículos pasen simultáneamente.",
    "examRelevant": true
  },
  "SR-17": {
    "nameEs": "Peso máximo",
    "nameEn": "Maximum weight",
    "descriptionEn": "Indicates the maximum gross vehicle weight (in metric tons) allowed on this road or structure. Vehicles exceeding the posted weight are prohibited.",
    "descriptionEs": "Indica el peso bruto vehicular máximo (en toneladas métricas) permitido en esta vía o estructura. Se prohíbe el paso de vehículos que excedan el peso indicado.",
    "examRelevant": true
  },
  "SR-20": {
    "nameEs": "No parar",
    "nameEn": "No stopping",
    "descriptionEn": "No stopping allowed. Both parking and temporary stopping are prohibited on this roadway. Distinguished from the no parking sign (SR-19) by having two diagonal slashes forming an X instead of one.",
    "descriptionEs": "Prohibido detenerse. Se prohíbe tanto el estacionamiento como la parada temporal en esta vía. Se distingue de la señal de no estacionarse (SR-19) por tener dos diagonales formando una X en lugar de una.",
    "examRelevant": true
  },
